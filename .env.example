# Supabase 配置
# 请替换为你的实际值（不要包含引号）

VITE_SUPABASE_URL=你的Supabase项目URL
VITE_SUPABASE_ANON_KEY=你的SupabaseAnonKey

# MiniMax AI 配置
VITE_MINIMAX_API_KEY=你的MiniMax Key

# Pinecone 向量数据库（可选，用于RAG）
VITE_PINECONE_API_KEY=你的Pinecone Key
VITE_PINECONE_INDEX=萌芽日记

# Jina Embedding（可选，用于RAG）
VITE_JINA_API_KEY=你的Jina Key
